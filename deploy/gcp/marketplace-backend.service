[Unit]
Description=Elashes Marketplace Backend FastAPI
After=network.target elashesbackend.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/elashes/marketplace/backend_marketplace
EnvironmentFile=/opt/elashes/marketplace/backend_marketplace/.env
ExecStart=/opt/elashes/marketplace/backend_marketplace/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8001 --workers 1
Restart=always
RestartSec=3
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
